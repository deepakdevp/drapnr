{
  "expo": {
    "name": "Drapnr",
    "slug": "drapnr",
    "version": "0.1.0",
    "scheme": "drapnr",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B6B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drapnr.app",
      "associatedDomains": ["applinks:drapnr.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "Drapnr needs camera access to capture your outfits from all angles.",
        "NSPhotoLibraryUsageDescription": "Drapnr needs photo library access to save your outfit photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B6B"
      },
      "package": "com.drapnr.app",
      "permissions": ["CAMERA"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "drapnr.com",
              "pathPrefix": "/outfit"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Drapnr needs camera access to capture your outfits.",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": ""
    }
  }
}
